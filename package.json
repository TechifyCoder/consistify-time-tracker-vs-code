{
  "name": "consistify-time-tracker",
  "displayName": "Consistify Time Tracker",
  "description": "Automatically tracks your active coding time in VS Code and syncs it to your Consistify dashboard. Stay consistent and build better coding habits.",
  "version": "1.0.0",
  "publisher": "satishpatel",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TechifyCoder/consistify-time-tracker-vs-code"
  },
  "homepage": "https://consis-sigma.vercel.app",
  "bugs": {
    "url": "https://github.com/TechifyCoder/consistify-time-tracker-vs-code/issues"
  },
  "keywords": [
    "time tracker",
    "coding time",
    "productivity",
    "consistify",
    "habit tracker",
    "wakatime",
    "activity",
    "stats",
    "dashboard"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "consistify.setApiKey",
        "title": "Consistify: Set API Key"
      },
      {
        "command": "consistify.clearApiKey",
        "title": "Consistify: Clear API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
