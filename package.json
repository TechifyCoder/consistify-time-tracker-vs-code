{
  "name": "consistify-time-tracker",
  "displayName": "Consistify Time Tracker",
  "description": "Tracks your active coding time and syncs it to your Consistify dashboard.",
  "version": "0.0.1",
  "publisher": "consistify",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "consistify.setApiKey",
        "title": "Consistify: Set API Key"
      },
      {
        "command": "consistify.clearApiKey",
        "title": "Consistify: Clear API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
